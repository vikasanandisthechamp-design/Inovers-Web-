default_platform(:android)

platform :android do
  desc "Build and upload to Play Store internal testing"
  lane :beta do
    # Build AAB (Android App Bundle)
    sh("cd ../.. && flutter build appbundle --release --dart-define=API_BASE_URL=https://sportgod-backend-production.up.railway.app")

    # Upload to Play Store internal testing
    upload_to_play_store(
      track: "internal",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Build release APK"
  lane :build_release do
    sh("cd ../.. && flutter build apk --release --dart-define=API_BASE_URL=https://sportgod-backend-production.up.railway.app")
  end

  desc "Build release AAB"
  lane :build_aab do
    sh("cd ../.. && flutter build appbundle --release --dart-define=API_BASE_URL=https://sportgod-backend-production.up.railway.app")
  end
end
