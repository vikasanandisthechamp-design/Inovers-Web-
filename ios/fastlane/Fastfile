default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight (CI — uses ASC API Key)"
  lane :beta do
    setup_ci if ENV['CI']

    # Authenticate with App Store Connect API key (no Apple ID password needed)
    api_key = app_store_connect_api_key(
      key_id:        ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:     ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content:   ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false,
    )

    # Auto-increment build number to avoid TestFlight rejection
    increment_build_number(
      build_number: latest_testflight_build_number(api_key: api_key) + 1,
    )

    # Build signed IPA
    build_app(
      workspace:     "Runner.xcworkspace",
      scheme:        "Runner",
      export_method: "app-store",
      clean:         true,
    )

    # Upload to TestFlight — skip waiting so the CI job finishes quickly
    upload_to_testflight(
      api_key:                          api_key,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Build release IPA (local — no upload)"
  lane :build_release do
    build_app(
      workspace:     "Runner.xcworkspace",
      scheme:        "Runner",
      export_method: "app-store",
      clean:         true,
    )
  end
end
